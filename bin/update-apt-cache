import sys
import syslog
import traceback
from pathlib import Path

from DebianDevelChangesBot.datasources import AptArchive


def main():
    syslog.openlog("ddc-bot-update-apt-cache")

    try:
        apt_archive = AptArchive(
            Path("/usr/share/debian-devel-changes-bot/bot-config/apt"),
            Path("/var/lib/debian-devel-changes-bot/apt"),
        )
        apt_archive.update_index()
    except Exception:
        syslog.syslog(traceback.format_exc())
        return -1

    return 0


if __name__ == "__main__":
    sys.exit(main())
